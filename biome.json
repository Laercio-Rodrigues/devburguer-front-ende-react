{
  "$schema": "https://biomejs.dev/schemas/1.8.0/schema.json",

  "formatter": {
    "indentWidth": 2,
    "lineWidth": 80
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    },
    "parser": {
      "jsx": true
    }
  }
}